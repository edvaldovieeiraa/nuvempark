# ============================================================
# NuvemPark — .gitignore (raiz cobre api/ web/ app/)
# ============================================================

# ---- Segredos (NUNCA versionar) ----
.env
.env.*
!.env.example
*.env
web/.env.local
api/.env
app/android/key.properties
app/android/app/*.jks
app/android/app/*.keystore
*.jks
*.keystore
*.p12
*.pem

# ---- Node / npm ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Next.js / build web ----
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# ---- Vercel ----
.vercel/

# ---- Flutter / Dart ----
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/build/
app/**/build/
app/.pub-cache/
app/.pub/
**/*.g.dart.lock
app/android/.gradle/
app/android/local.properties
app/android/app/debug/
app/android/app/profile/
app/android/app/release/
app/ios/Flutter/Flutter.framework
app/ios/Flutter/Flutter.podspec
app/ios/Pods/
app/.fvm/

# ---- APK / AAB / binários grandes ----
*.apk
*.aab
*.symbols

# ---- Editores / OS ----
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
*.swp

# ---- Logs / temporários ----
*.log
tmp/
temp/

# ---- Claude Code (config local de máquina) ----
.claude/settings.local.json

# ---- Impeccable (config/cache local de máquina) ----
**/.impeccable/config.local.json
**/.impeccable/hook.cache.json
