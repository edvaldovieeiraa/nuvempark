# ParkFlow API — variáveis de ambiente
# Copie para .env e preencha.

# Servidor
PORT=8080
NODE_ENV=development

# Supabase (projeto ParkFlow: xrwrsswhoywzzhutzrjx)
SUPABASE_URL=https://xrwrsswhoywzzhutzrjx.supabase.co
# anon key — usada para o cliente tenant-scoped (RLS ativa)
SUPABASE_ANON_KEY=
# service_role — SOMENTE para operações administrativas explícitas. NUNCA no caminho normal.
SUPABASE_SERVICE_ROLE_KEY=

# JWT Secret do PROJETO Supabase (Settings → API → JWT Settings → JWT Secret).
# Necessário para o backend assinar JWTs tenant-scoped que a RLS aceita.
SUPABASE_JWT_SECRET=

# JWT do operador (HS256) — segredo NOSSO, separado do Supabase.
# Gere um segredo forte: openssl rand -hex 32
NUVEMPARK_JWT_SECRET=

# CORS (origens do app / painel em dev). Vírgula-separado. '*' só em dev.
CORS_ORIGINS=*

# ── Pagamento online (Pix pelo QR do cupom) ──────────────────────────────────
# Cifra as chaves de PSP guardadas em tenant_gateways (AES-256-GCM).
# 32 bytes em base64. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# PERDER esta chave = não decifrar mais NENHUMA chave de PSP. Guarde backup.
NUVEMPARK_CRYPTO_KEY=

# Asaas. Sandbox por padrão; produção: https://api.asaas.com/v3
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3

# Wallet da PLATAFORMA — recebe o split. Vazio = sem split (tudo do tenant).
ASAAS_WALLET_PLATAFORMA=

# Token do webhook (definido por você no painel do Asaas → Integrações → Webhooks).
# O Asaas o envia no header `asaas-access-token`; sem ele, a rota devolve 401.
ASAAS_WEBHOOK_TOKEN=

# CPF/CNPJ do cliente genérico das cobranças avulsas. O Asaas EXIGE um `customer`
# na cobrança e quem paga o ticket é anônimo (não pedimos CPF a quem só quer sair).
ASAAS_CPFCNPJ_CLIENTE_PADRAO=
